<% layout("layouts/boilerplate") %>

<style>
    #filters {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
    }

    .filter {
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
        opacity: 0.8;
    }

    .filter:hover {
        opacity: 1;
        cursor: pointer;
    }

    .tax-info {
        display: none;
    }

    .tax-toggle {
        border: 1px solid black;
        border-radius: 1rem;
        height: 3.25rem;
        padding: 1rem;
        margin-left: 3rem;
        display: flex;
        align-items: center;
    }
</style>

<!-- FILTERS -->
<div id="filters">

    <div class="filter">
        <a href="/listings?trending=true" style="text-decoration:none;color:inherit;">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=Rooms" style="text-decoration:none;color:inherit;">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Room</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=Iconic" style="text-decoration:none;color:inherit;">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=Mountains" style="text-decoration:none;color:inherit;">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=Castles" style="text-decoration:none;color:inherit;">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castles</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=Amazing Pools" style="text-decoration:none;color:inherit;">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=Camping" style="text-decoration:none;color:inherit;">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=Farmes" style="text-decoration:none;color:inherit;">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farmes</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=Arctic" style="text-decoration:none;color:inherit;">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </a>
    </div>

    <div class="filter">
        <a href="/listings?category=Boats" style="text-decoration:none;color:inherit;">
            <div><i class="fa-solid fa-sailboat"></i></div>
            <p>Boats</p>
        </a>
    </div>

    <!-- TAX SWITCH -->
    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after Taxes</label>
        </div>
    </div>
</div>

<!-- LISTINGS -->
<div class="row mt-3">
    <% for (let listing of allListings) { %>

    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

        <a href="/listings/<%= listing._id %>" style="text-decoration:none; color:inherit;">

            <div class="card listing-card" style="width: 100%; border-radius: 15px; overflow:hidden;">

                <img 
                    src="<%= listing.image?.url || listing.image %>"
                    class="card-img-top"
                    alt="listing_image"
                    style="height: 18rem; object-fit: cover;"
                />

                <div class="card-body p-3">
                    <p class="card-text m-0 price-box" data-price="<%= listing.price %>">
                        <b><%= listing.title %></b><br>
                        ₹<span class="main-price"><%= listing.price.toLocaleString("en-IN") %></span> / night
                        <i class="tax-info">&nbsp;+18% GST</i>
                    </p>
                </div>

            </div>

        </a>

    </div>

    <% } %>
</div>

<!-- TAX TOGGLE SCRIPT -->
<script>
    let taxSwitch = document.getElementById("switchCheckDefault");

    taxSwitch.addEventListener("change", () => {
        let priceBoxes = document.querySelectorAll(".price-box");

        priceBoxes.forEach(box => {
            let basePrice = parseFloat(box.getAttribute("data-price"));
            let mainPriceEl = box.querySelector(".main-price");

            if (taxSwitch.checked) {
                let finalPrice = Math.round(basePrice * 1.18);
                mainPriceEl.innerText = finalPrice.toLocaleString("en-IN");
            } else {
                mainPriceEl.innerText = basePrice.toLocaleString("en-IN");
            }
        });
    });
</script>
